[run]
source = story_runtime_core
omit =
    */tests/*
    */test_*.py
    */__pycache__/*
    */site-packages/*
    setup.py
    story_runtime_core/branching/*
    story_runtime_core/goc_solo_builtin_*.py
    story_runtime_core/builtin_experience_templates.py
    story_runtime_core/experience_template_models.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise AssertionError
    raise NotImplementedError
    if 0:
    if False:
    if TYPE_CHECKING:
