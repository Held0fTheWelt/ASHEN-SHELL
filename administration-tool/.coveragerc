# Single tracer root for the flat administration-tool tree (avoids multiple --cov=module
# flags that trigger "module-not-measured" / "module-not-imported" with Coverage.py 7.x).
[run]
source = .
omit =
    tests/*
    */tests/*
    */site-packages/*
    */__pycache__/*
    .venv/*
    venv/*

branch = True

[report]
omit =
    tests/*
    */tests/*
precision = 2
skip_empty = True

exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
